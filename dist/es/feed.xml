      &lt;/h1&gt;
    &lt;/div&gt;
    &lt;div class=&quot;mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none&quot;&gt;
      &lt;dl class=&quot;grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-2&quot;&gt;
